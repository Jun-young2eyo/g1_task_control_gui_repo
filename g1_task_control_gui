#!/usr/bin/env python3
"""Tkinter GUI for the G1 Inspire hand task controller."""

from __future__ import annotations

import math
import sys
import threading
import types
import tkinter as tk
from importlib.machinery import SourceFileLoader
from importlib.util import module_from_spec, spec_from_loader
from pathlib import Path
from tkinter import messagebox, ttk

import rclpy


def _load_cli_controller():
    source = Path(__file__).with_name("g1_task_control_ros2")
    loader = SourceFileLoader("g1_task_control_ros2_shared", str(source))
    spec = spec_from_loader(loader.name, loader)
    if spec is None:
        module = types.ModuleType(loader.name)
        sys.modules[loader.name] = module
        loader.exec_module(module)
        return module
    module = module_from_spec(spec)
    sys.modules[loader.name] = module
    loader.exec_module(module)
    return module


_controller = _load_cli_controller()
G1TaskControl = _controller.G1TaskControl
TASK_TABLE = _controller.TASK_TABLE
MANUAL_JOINT_LABELS = ("Thumb yaw", "Thumb pitch", "Index", "Middle", "Ring", "Pinky")
MANUAL_SLIDER_MIN = 0.0
MANUAL_SLIDER_MAX_VALUES = tuple(math.degrees(value) for value in (1.3, 0.6, 1.7, 1.7, 1.7, 1.7))
MANUAL_SLIDER_DURATION_SEC = 0.1
MANUAL_SLIDER_KEY_STEP = 0.1
MANUAL_SLIDER_SHIFT_KEY_STEP = 1.0
FOCUS_BORDER_COLOR = "#1e88ff"
NORMAL_BORDER_COLOR = "#d0d0d0"


class G1TaskControlApp:
    def __init__(self, root: tk.Tk, node: G1TaskControl) -> None:
        self.root = root
        self.node = node
        self.busy = False
        self.selected_hand = tk.StringVar(value=self.node.current_hand())
        self.task_text = tk.StringVar(value="No task selected")
        self.phase_text = tk.StringVar(value="Phase: none")
        self.status_text = tk.StringVar(value="Ready")
        self.duration_value = tk.StringVar(value=f"{self.node.duration_sec:.2f}")
        self.duration_spinbox = None
        self.manual_entry = None
        self.manual_value = tk.StringVar(value="")
        self.manual_slider_vars = []
        self.manual_slider_value_labels = []
        self.manual_slider_widgets = []
        self.manual_slider_active = False
        self.manual_slider_pending = None
        self.manual_slider_after_id = None
        self.manual_slider_worker_running = False
        self.manual_slider_updating = False
        self.selected_task_number = None
        self.task_button_frames = {}
        self.buttons = []

        self._configure_focus_styles()
        self.root.title("G1 Inspire Hand Control")
        self.root.minsize(680, 620)
        self.root.protocol("WM_DELETE_WINDOW", self.on_window_close)
        self._build_ui()
        self._bind_keys()
        self._refresh_state()

    def _build_ui(self) -> None:
        outer = ttk.Frame(self.root, padding=12)
        outer.grid(row=0, column=0, sticky="nsew")
        self.root.columnconfigure(0, weight=1)
        self.root.rowconfigure(0, weight=1)
        outer.columnconfigure(0, weight=1)

        title = ttk.Label(outer, text="G1 Inspire Hand Control", font=("TkDefaultFont", 16, "bold"))
        title.grid(row=0, column=0, sticky="w")

        status = ttk.Frame(outer)
        status.grid(row=1, column=0, sticky="ew", pady=(8, 12))
        status.columnconfigure(0, weight=1)
        status.columnconfigure(1, weight=1)
        status.columnconfigure(2, weight=1)
        ttk.Label(status, textvariable=self.task_text).grid(row=0, column=0, sticky="w")
        ttk.Label(status, textvariable=self.phase_text).grid(row=0, column=1, sticky="w")
        ttk.Label(status, textvariable=self.status_text).grid(row=0, column=2, sticky="e")

        hand_frame = ttk.LabelFrame(outer, text="Hand")
        hand_frame.grid(row=2, column=0, sticky="ew", pady=(0, 12))
        hand_frame.columnconfigure(3, weight=1)
        for index, hand in enumerate(("left", "right")):
            button = ttk.Radiobutton(
                hand_frame,
                text=hand.capitalize(),
                value=hand,
                variable=self.selected_hand,
                command=lambda hand=hand: self.select_hand(hand),
            )
            button.grid(row=0, column=index, padx=8, pady=8, sticky="w")
            self._bind_focus_style(button, "TRadiobutton", "Focused.TRadiobutton")
        ttk.Label(hand_frame, text="Duration (sec, 0.1-5.0)").grid(row=0, column=2, padx=(24, 6), pady=8, sticky="e")
        duration = ttk.Spinbox(
            hand_frame,
            from_=0.1,
            to=5.0,
            increment=0.1,
            width=6,
            textvariable=self.duration_value,
            command=self.apply_duration,
        )
        duration.grid(row=0, column=3, padx=8, pady=8, sticky="w")
        duration.bind("<Return>", lambda _event: self.apply_duration_and_release_focus())
        duration.bind("<FocusOut>", lambda _event: self.apply_duration())
        self.duration_spinbox = duration

        tasks = ttk.LabelFrame(outer, text="Tasks")
        tasks.grid(row=3, column=0, sticky="nsew", pady=(0, 12))
        for col in range(3):
            tasks.columnconfigure(col, weight=1)
        for number, task in TASK_TABLE.items():
            row = (number - 1) // 3
            col = (number - 1) % 3
            text = f"{number}. {task.name}"
            button = self._add_button(tasks, text, lambda number=number: self.select_task(number), row, col, bind_focus=False)
            self.task_button_frames[number] = button._focus_frame
            self._bind_task_button_focus(button, number)

        manual = ttk.LabelFrame(outer, text="Manual Angles (deg: thumb_yaw thumb_pitch index middle ring pinky)")
        manual.grid(row=4, column=0, sticky="ew", pady=(0, 12))
        manual.columnconfigure(1, weight=1)
        entry = ttk.Entry(manual, textvariable=self.manual_value)
        entry.grid(row=0, column=0, columnspan=2, sticky="ew", padx=6, pady=6)
        entry.bind("<Return>", lambda _event: self.send_manual_action())
        self.manual_entry = entry
        self._add_button(manual, "Send Manual", self.send_manual_action, 0, 2)

        for index, (label, max_value) in enumerate(zip(MANUAL_JOINT_LABELS, MANUAL_SLIDER_MAX_VALUES)):
            value = tk.DoubleVar(value=0.0)
            self.manual_slider_vars.append(value)
            ttk.Label(manual, text=label).grid(row=index + 1, column=0, sticky="w", padx=6, pady=2)
            slider = ttk.Scale(
                manual,
                from_=MANUAL_SLIDER_MIN,
                to=max_value,
                variable=value,
                command=lambda _value, index=index: self.on_manual_slider_change(index),
            )
            slider.grid(row=index + 1, column=1, sticky="ew", padx=6, pady=2)
            slider.bind("<ButtonPress-1>", lambda event, index=index: self.start_manual_slider_drag(event, index))
            slider.bind("<ButtonRelease-1>", self.finish_manual_slider_drag)
            slider.bind("<Left>", lambda event, index=index: self.adjust_manual_slider_with_key(event, index, -1))
            slider.bind("<Right>", lambda event, index=index: self.adjust_manual_slider_with_key(event, index, 1))
            slider.bind("<Shift-Left>", lambda event, index=index: self.adjust_manual_slider_with_key(event, index, -1, shifted=True))
            slider.bind("<Shift-Right>", lambda event, index=index: self.adjust_manual_slider_with_key(event, index, 1, shifted=True))
            slider.bind("<Up>", lambda event, index=index: self.focus_manual_slider(event, index - 1))
            slider.bind("<Down>", lambda event, index=index: self.focus_manual_slider(event, index + 1))
            slider.bind("<FocusIn>", lambda event: event.widget.configure(style="Focused.Horizontal.TScale"))
            slider.bind("<FocusOut>", lambda event: event.widget.configure(style="Horizontal.TScale"))
            self.manual_slider_widgets.append(slider)
            value_label = ttk.Label(manual, text="0.0", width=6, anchor="e")
            value_label.grid(row=index + 1, column=2, sticky="e", padx=6, pady=2)
            self.manual_slider_value_labels.append(value_label)

        actions = ttk.LabelFrame(outer, text="Commands")
        actions.grid(row=5, column=0, sticky="ew")
        for col in range(3):
            actions.columnconfigure(col, weight=1)

        self._add_action(actions, "Setting", "s", self.node.setting, 0, 0)
        self._add_action(actions, "Prepare / Start", "g", self.node.grasp, 0, 1)
        self._add_action(actions, "Open", "o", lambda: self.node.open_hand(self.node.current_hand()), 0, 2)
        self._add_action(actions, "Close", "c", lambda: self.node.close_hand(self.node.current_hand()), 1, 0)
        self._add_action(actions, "Close Both + Quit", "q", self.close_both_and_quit, 1, 1, colspan=2)

    def _configure_focus_styles(self) -> None:
        self.style = ttk.Style()
        self.style.configure("Focused.TButton", borderwidth=3, relief="solid", bordercolor=FOCUS_BORDER_COLOR, focuscolor=FOCUS_BORDER_COLOR)
        self.style.map("Focused.TButton", relief=[("focus", "solid"), ("!focus", "solid")])
        self.style.configure("Focused.TRadiobutton", focuscolor=FOCUS_BORDER_COLOR, foreground=FOCUS_BORDER_COLOR)
        self.style.configure("Focused.Horizontal.TScale", background=FOCUS_BORDER_COLOR, troughcolor="#d8eaff")

    def _bind_focus_style(self, widget, normal_style: str, focused_style: str) -> None:
        widget.configure(takefocus=True)
        widget.bind("<ButtonPress-1>", lambda event: event.widget.focus_set(), add="+")
        widget.bind("<FocusIn>", lambda _event: widget.configure(style=focused_style), add="+")
        widget.bind("<FocusOut>", lambda _event: widget.configure(style=normal_style), add="+")

    def _set_slider_focus(self, frame, focused: bool) -> None:
        color = FOCUS_BORDER_COLOR if focused else NORMAL_BORDER_COLOR
        frame.configure(highlightbackground=color, highlightcolor=color)

    def _bind_focus_border(self, widget, frame) -> None:
        widget.configure(takefocus=True)
        widget.bind("<ButtonPress-1>", lambda event: event.widget.focus_set(), add="+")
        widget.bind("<FocusIn>", lambda _event: self._set_slider_focus(frame, True), add="+")
        widget.bind("<FocusOut>", lambda _event: self._set_slider_focus(frame, False), add="+")

    def _bind_task_button_focus(self, button, number: int) -> None:
        button.configure(takefocus=True)
        button.bind("<ButtonPress-1>", lambda event: event.widget.focus_set(), add="+")
        button.bind("<FocusIn>", lambda _event, number=number: self._update_task_button_frame(number, True), add="+")
        button.bind("<FocusOut>", lambda _event, number=number: self._update_task_button_frame(number, False), add="+")

    def _update_task_button_frame(self, number: int, focused: bool = False) -> None:
        frame = self.task_button_frames.get(number)
        if frame is None:
            return
        color = FOCUS_BORDER_COLOR if focused or number == self.selected_task_number else NORMAL_BORDER_COLOR
        frame.configure(highlightbackground=color, highlightcolor=color)

    def _refresh_task_button_selection(self) -> None:
        focused = self.root.focus_get()
        for number, frame in self.task_button_frames.items():
            is_focused = getattr(focused, "_focus_frame", None) is frame
            color = FOCUS_BORDER_COLOR if is_focused or number == self.selected_task_number else NORMAL_BORDER_COLOR
            frame.configure(highlightbackground=color, highlightcolor=color)

    def _add_button(self, parent, text: str, command, row: int, column: int, colspan: int = 1, bind_focus: bool = True):
        frame = tk.Frame(parent, highlightthickness=2, highlightbackground=NORMAL_BORDER_COLOR, bd=0)
        frame.grid(row=row, column=column, columnspan=colspan, sticky="ew", padx=6, pady=6)
        frame.columnconfigure(0, weight=1)
        button = ttk.Button(frame, text=text, command=command)
        button._focus_frame = frame
        button.grid(row=0, column=0, sticky="ew", padx=1, pady=1)
        if bind_focus:
            self._bind_focus_border(button, frame)
        self.buttons.append(button)
        return button

    def _add_action(self, parent, label, key, action, row, column, colspan=1) -> None:
        self._add_button(parent, f"{label} ({key})", lambda: self.run_action(label, action), row, column, colspan)

    def _bind_keys(self) -> None:
        self.root.bind_all("<Button-1>", self._release_entry_focus_on_click, add="+")
        self.root.bind_all("r", lambda event: self._run_shortcut(event, lambda: self.select_hand("right")))
        self.root.bind_all("l", lambda event: self._run_shortcut(event, lambda: self.select_hand("left")))
        self.root.bind_all("s", lambda event: self._run_shortcut(event, lambda: self.run_action("Setting", self.node.setting)))
        self.root.bind_all("g", lambda event: self._run_shortcut(event, lambda: self.run_action("Prepare / Start", self.node.grasp)))
        self.root.bind_all("o", lambda event: self._run_shortcut(event, lambda: self.run_action("Open", lambda: self.node.open_hand(self.node.current_hand()))))
        self.root.bind_all("c", lambda event: self._run_shortcut(event, lambda: self.run_action("Close", lambda: self.node.close_hand(self.node.current_hand()))))
        self.root.bind_all("q", lambda event: self._run_shortcut(event, lambda: self.run_action("Close Both + Quit", self.close_both_and_quit)))
        for number in TASK_TABLE:
            self.root.bind_all(str(number), lambda event, number=number: self._run_shortcut(event, lambda: self.select_task(number)))

    def _run_shortcut(self, event, action):
        if event.widget in (self.duration_spinbox, self.manual_entry):
            return None
        action()
        return "break"

    def _release_entry_focus_on_click(self, event):
        if event.widget in (self.duration_spinbox, self.manual_entry):
            return None
        if event.widget in self.manual_slider_widgets:
            return None
        self.root.after_idle(self.root.focus_set)
        return None

    def apply_duration(self) -> bool:
        try:
            duration = float(self.duration_value.get())
        except ValueError:
            messagebox.showerror("G1 Inspire Hand Control", "Duration must be a number.")
            self.duration_value.set(f"{self.node.duration_sec:.2f}")
            return False
        if not 0.1 <= duration <= 5.0:
            messagebox.showerror("G1 Inspire Hand Control", "Duration must be between 0.1 and 5.0 seconds.")
            self.duration_value.set(f"{self.node.duration_sec:.2f}")
            return False
        self.node.duration_sec = duration
        self.duration_value.set(f"{duration:.2f}")
        self.status_text.set(f"Duration: {duration:.2f} sec")
        return True

    def apply_duration_and_release_focus(self) -> str:
        if self.apply_duration():
            self.root.focus_set()
        return "break"

    def select_hand(self, hand: str) -> None:
        if self.busy:
            return
        self.node.select_hand(hand)
        self.selected_hand.set(hand)
        self._refresh_state(f"Selected {hand} hand")

    def select_task(self, number: int) -> None:
        if self.busy:
            return
        self.node.select_task(number)
        self.selected_task_number = number
        self.selected_hand.set(self.node.current_hand())
        self._refresh_task_button_selection()
        self._refresh_state(f"Selected task {number}")

    def run_action(self, label: str, action) -> None:
        if self.busy or self.manual_slider_worker_running:
            return
        if not self.apply_duration():
            return
        self._set_busy(True, f"Running {label}...")

        def worker() -> None:
            error = None
            try:
                action()
            except Exception as exc:  # noqa: BLE001
                error = exc
            self.root.after(0, lambda: self._finish_action(label, error))

        threading.Thread(target=worker, daemon=True).start()

    def current_manual_slider_values(self) -> tuple[float, ...]:
        return tuple(value.get() for value in self.manual_slider_vars)

    def set_manual_slider_values(self, values: tuple[float, ...]) -> None:
        self.manual_slider_updating = True
        try:
            for variable, value_label, value, max_value in zip(
                self.manual_slider_vars, self.manual_slider_value_labels, values, MANUAL_SLIDER_MAX_VALUES
            ):
                slider_value = min(max(value, MANUAL_SLIDER_MIN), max_value)
                variable.set(slider_value)
                value_label.configure(text=f"{slider_value:.1f}")
            self.manual_value.set(" ".join(f"{value:.3f}" for value in values))
        finally:
            self.manual_slider_updating = False

    def on_manual_slider_change(self, index: int) -> None:
        values = self.current_manual_slider_values()
        self.manual_slider_value_labels[index].configure(text=f"{values[index]:.1f}")
        self.manual_value.set(" ".join(f"{value:.3f}" for value in values))
        if self.manual_slider_updating or not self.manual_slider_active:
            return
        self.queue_manual_slider_send()

    def start_manual_slider_drag(self, event, _index: int) -> None:
        event.widget.focus_set()
        if self.busy or self.manual_slider_worker_running:
            return
        if not self.apply_duration():
            return
        self.manual_slider_active = True
        self.queue_manual_slider_send()

    def finish_manual_slider_drag(self, _event) -> None:
        if not self.manual_slider_active:
            return
        self.queue_manual_slider_send()
        self.manual_slider_active = False

    def adjust_manual_slider_with_key(self, event, index: int, direction: int, shifted: bool = False):
        if self.busy or self.manual_slider_worker_running:
            return "break"
        if not self.apply_duration():
            return "break"
        step = MANUAL_SLIDER_SHIFT_KEY_STEP if shifted else MANUAL_SLIDER_KEY_STEP
        value = self.manual_slider_vars[index].get() + direction * step
        max_value = MANUAL_SLIDER_MAX_VALUES[index]
        value = min(max(value, MANUAL_SLIDER_MIN), max_value)
        self.manual_slider_vars[index].set(value)
        self.on_manual_slider_change(index)
        self.queue_manual_slider_send()
        event.widget.focus_set()
        return "break"

    def focus_manual_slider(self, _event, index: int):
        index = min(max(index, 0), len(self.manual_slider_widgets) - 1)
        self.manual_slider_widgets[index].focus_set()
        return "break"

    def queue_manual_slider_send(self) -> None:
        if self.busy:
            return
        self.manual_slider_pending = self.current_manual_slider_values()
        if self.manual_slider_worker_running or self.manual_slider_after_id is not None:
            return
        self.manual_slider_after_id = self.root.after(80, self.start_pending_manual_slider_send)

    def start_pending_manual_slider_send(self) -> None:
        self.manual_slider_after_id = None
        if self.busy or self.manual_slider_worker_running or self.manual_slider_pending is None:
            return
        values = self.manual_slider_pending
        self.manual_slider_pending = None
        hand = self.node.current_hand()
        self.manual_slider_worker_running = True
        self.status_text.set("Running Manual slider...")

        def worker() -> None:
            error = None
            success = False
            original_duration = self.node.duration_sec
            try:
                self.node.duration_sec = min(original_duration, MANUAL_SLIDER_DURATION_SEC)
                success = self.node.send_values(hand, values, "manual-slider")
                if success:
                    self.node.current_phase = "manual"
                    print(f"manual-slider: {hand}")
                    print(_controller.format_command_values(values))
            except Exception as exc:  # noqa: BLE001
                error = exc
            finally:
                self.node.duration_sec = original_duration
            self.root.after(0, lambda: self.finish_manual_slider_send(error, success))

        threading.Thread(target=worker, daemon=True).start()

    def finish_manual_slider_send(self, error: Exception | None, success: bool) -> None:
        self.manual_slider_worker_running = False
        if error is not None:
            self.status_text.set("Failed: Manual slider")
            messagebox.showerror("G1 Inspire Hand Control", str(error))
            self.manual_slider_pending = None
            return
        if self.manual_slider_pending is not None:
            self.manual_slider_after_id = self.root.after(40, self.start_pending_manual_slider_send)
            return
        if success:
            self._refresh_state("Done: Manual slider")
        else:
            self.status_text.set("Manual slider command was not accepted")

    def parse_manual_values(self) -> tuple[float, ...] | None:
        raw = self.manual_value.get().strip().replace(",", " ").split()
        if len(raw) != 6:
            messagebox.showerror(
                "G1 Inspire Hand Control",
                "Enter exactly six degree values: thumb_yaw thumb_pitch index middle ring pinky.",
            )
            return None
        try:
            return tuple(float(value) for value in raw)
        except ValueError:
            messagebox.showerror("G1 Inspire Hand Control", "Manual angles must be numbers.")
            return None

    def send_manual_action(self) -> None:
        if self.busy or self.manual_slider_worker_running:
            return
        if not self.apply_duration():
            return
        values = self.parse_manual_values()
        if values is None:
            return
        self.set_manual_slider_values(values)
        hand = self.node.current_hand()
        self._set_busy(True, "Running Manual...")

        def worker() -> None:
            error = None
            try:
                if self.node.send_values(hand, values, "manual"):
                    self.node.current_phase = "manual"
                    print(f"manual: {hand}")
                    print(_controller.format_command_values(values))
            except Exception as exc:  # noqa: BLE001
                error = exc
            self.root.after(0, lambda: self._finish_action("Manual", error))

        threading.Thread(target=worker, daemon=True).start()

    def close_both_and_quit(self) -> None:
        self.node.close_both_hands()
        self.root.after(0, self.root.quit)

    def _finish_action(self, label: str, error: Exception | None) -> None:
        self._set_busy(False)
        if error is not None:
            self.status_text.set(f"Failed: {label}")
            messagebox.showerror("G1 Inspire Hand Control", str(error))
            return
        self._refresh_state(f"Done: {label}")

    def _set_busy(self, busy: bool, status: str | None = None) -> None:
        self.busy = busy
        state = "disabled" if busy else "normal"
        for button in self.buttons:
            button.configure(state=state)
        if status is not None:
            self.status_text.set(status)

    def _refresh_state(self, status: str | None = None) -> None:
        if self.node.current_task is None:
            self.task_text.set("No task selected")
        else:
            self.task_text.set(f"Task: {self.node.current_task.name}")
        self.phase_text.set(f"Phase: {self.node.current_phase}")
        self.selected_hand.set(self.node.current_hand())
        if status is not None:
            self.status_text.set(status)

    def on_window_close(self) -> None:
        if self.busy:
            return
        self.root.destroy()


def main() -> None:
    rclpy.init(args=sys.argv)
    node = G1TaskControl()
    root = tk.Tk()
    try:
        node.init_task_control()
        G1TaskControlApp(root, node)
        root.mainloop()
    finally:
        root.destroy()
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
